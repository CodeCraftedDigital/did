---
const features = [
  {
    icon: "/icons/Since-1928.svg",
    title: "Since 1928",
    description: "Nearly a century of water-control expertise."
  },
  {
    icon: "/icons/Purchase-Options.svg",
    title: "Purchase Options",
    description: "Built for long-term project needs."
  },
  {
    icon: "/icons/Emergency-Availability.svg",
    title: "Emergency Availability",
    description: "Rapid response when it matters most."
  },
  {
    icon: "/icons/Nationwide-Support.svg",
    title: "Nationwide Support",
    description: "Where you need us, when you need us."
  }
];
---

<section class="py-16 lg:py-24 bg-dark">
  <div class="container-custom">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {features.map((feature) => (
        <div class="bg-dark-light border border-white/5 rounded-lg p-6 lg:p-8 text-center hover:border-primary-light/30 transition-colors">
          <div class="w-16 h-16 mx-auto mb-4 flex items-center justify-center">
            <img src={feature.icon} alt={feature.title} class="w-12 h-12 object-contain" />
          </div>
          <h3 class="text-primary-light text-xs uppercase tracking-wider font-semibold mb-2">
            {feature.title}
          </h3>
          <p class="text-gray-light text-sm leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
