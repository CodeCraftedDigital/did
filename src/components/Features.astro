---
const features = [
  {
    icon: "/icons/Since-1928.svg",
    title: "Since 1928",
    description: "Nearly a century of water-control expertise."
  },
  {
    icon: "/icons/Purchase-Options.svg",
    title: "Purchase Options",
    description: "Built for long-term project needs."
  },
  {
    icon: "/icons/Emergency-Availability.svg",
    title: "Emergency Availability",
    description: "Rapid response when it matters most."
  },
  {
    icon: "/icons/Nationwide-Support.svg",
    title: "Nationwide Support",
    description: "Where you need us, when you need us."
  }
];
---

<section class="py-16 lg:py-20 bg-light">
  <div class="container-custom">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      {features.map((feature) => (
        <div class="bg-white border border-gray-200 rounded-lg p-5 lg:p-6 text-center">
          <div class="flex items-center justify-center mb-4 h-16">
            <img src={feature.icon} alt={feature.title} class="h-14 w-auto object-contain" />
          </div>
          <h3 class="text-primary-light text-[10px] uppercase tracking-[0.15em] font-bold mb-2">
            {feature.title}
          </h3>
          <p class="text-gray text-xs leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
