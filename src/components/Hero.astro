---

---

<section class="relative min-h-screen flex items-center pt-20">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <img 
      src="/images/Header-BG.jpg" 
      alt="Cofferdam in water"
      class="w-full h-full object-cover"
    />
    <div class="gradient-overlay"></div>
  </div>
  
  <!-- Decorative line at top -->
  <div class="absolute top-20 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-light/30 to-transparent"></div>
  
  <!-- Content -->
  <div class="relative z-10 container-custom py-20 lg:py-32">
    <div class="max-w-2xl">
      <p class="section-label mb-6">Water Solutions Since 1928</p>
      
      <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold leading-tight mb-6">
        Portable<br />
        <span class="text-primary-light italic">Water-Filled</span><br />
        Cofferdams
      </h1>
      
      <p class="text-lg sm:text-xl text-gray-light mb-8 max-w-lg leading-relaxed">
        The proven solution for construction, flood control, dewatering, and emergency water diversion.
      </p>
      
      <div class="flex flex-wrap gap-4">
        <a href="#contact" class="btn-primary">
          Get A Quote
        </a>
        <a href="#applications" class="btn-primary-filled">
          See Applications
        </a>
      </div>
    </div>
  </div>
  
  <!-- Bottom gradient fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-dark to-transparent"></div>
</section>
