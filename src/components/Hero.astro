---

---

<section class="relative min-h-screen flex items-center">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <img 
      src="/images/Header-BG.jpg" 
      alt="Cofferdam in water"
      class="w-full h-full object-cover"
    />
    <div class="gradient-overlay"></div>
  </div>
  
  <!-- Content -->
  <div class="relative z-10 container-custom py-20 lg:py-32">
    <div class="max-w-2xl">
      <p class="text-primary-light text-xs uppercase tracking-[0.25em] font-semibold mb-6">Water Solutions Since 1928</p>
      
      <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold leading-[1.1] mb-6">
        <span class="text-white">Portable</span><br />
        <span class="text-primary-light italic font-light">Water-Filled</span><br />
        <span class="text-white">Cofferdams</span>
      </h1>
      
      <p class="text-base sm:text-lg text-white/80 mb-8 max-w-md leading-relaxed">
        The proven solution for construction, flood control, dewatering, and emergency water diversion.
      </p>
      
      <div class="flex flex-wrap gap-3">
        <a href="#contact" class="btn-primary text-xs">
          Get A Quote
        </a>
        <a href="#applications" class="btn-primary-filled text-xs">
          See Applications
        </a>
      </div>
    </div>
  </div>
</section>
