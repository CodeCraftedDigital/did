---
const projects = [
  {
    image: "/images/Field-Proof-Image-01.jpg",
    category: "Bridge & Waterfront",
    title: "Waterfront Bridge Repair",
    description: "Temporary water control for bridge rehabilitation and infrastructure work."
  },
  {
    image: "/images/Field-Proof-Image-02.jpg",
    category: "Municipal Response",
    title: "Urban Flood Diversion",
    description: "Rapid deployment to protect critical infrastructure and communities."
  },
  {
    image: "/images/Field-Proof-Image-03.jpg",
    category: "Industrial Sites",
    title: "Industrial Dewatering",
    description: "Efficient dewatering support for complex industrial conditions."
  }
];
---

<section id="projects" class="py-16 lg:py-20 bg-dark">
  <div class="container-custom">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10">
      <div>
        <p class="text-white/40 text-[10px] uppercase tracking-[0.2em] font-bold mb-2">Field Proof</p>
        <h2 class="text-2xl lg:text-3xl font-bold text-white">
          Proven in <span class="text-primary-light">The Field</span>
        </h2>
      </div>
      <a href="#contact" class="btn-primary-filled text-xs w-fit">
        Start A Project
      </a>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map((project) => (
        <div class="group">
          <div class="relative overflow-hidden rounded-lg mb-4 aspect-[16/10]">
            <img 
              src={project.image} 
              alt={project.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
          </div>
          <p class="text-primary-light text-[10px] uppercase tracking-[0.1em] font-bold mb-1">
            {project.category}
          </p>
          <h3 class="text-white font-semibold text-sm mb-1">
            {project.title}
          </h3>
          <p class="text-white/50 text-xs leading-relaxed">
            {project.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
