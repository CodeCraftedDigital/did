---
const projects = [
  {
    image: "/images/Field-Proof-Image-01.jpg",
    category: "Bridge & Waterfront",
    title: "Waterfront Bridge Repair",
    description: "Temporary water control for bridge rehabilitation and infrastructure work."
  },
  {
    image: "/images/Field-Proof-Image-02.jpg",
    category: "Municipal Response",
    title: "Urban Flood Diversion",
    description: "Rapid deployment to protect critical infrastructure and communities."
  },
  {
    image: "/images/Field-Proof-Image-03.jpg",
    category: "Industrial Sites",
    title: "Industrial Dewatering",
    description: "Efficient dewatering support for complex industrial conditions."
  }
];
---

<section id="projects" class="py-16 lg:py-24 bg-dark">
  <div class="container-custom">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6 mb-12">
      <div>
        <p class="section-label">Field Proof</p>
        <h2 class="text-3xl lg:text-4xl font-bold">
          Proven in <span class="text-primary-light">The Field</span>
        </h2>
      </div>
      <a href="#contact" class="btn-primary-filled w-fit">
        Start A Project
      </a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {projects.map((project) => (
        <div class="group">
          <div class="relative overflow-hidden rounded-lg mb-4 aspect-[4/3]">
            <img 
              src={project.image} 
              alt={project.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
          </div>
          <p class="text-primary-light text-xs uppercase tracking-wider font-semibold mb-1">
            {project.category}
          </p>
          <h3 class="text-light font-semibold text-lg mb-2">
            {project.title}
          </h3>
          <p class="text-gray-light text-sm leading-relaxed">
            {project.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
